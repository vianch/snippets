NEXT_PUBLIC_BASE_URL=https://snippets.vianch.com
NEXT_PUBLIC_SUPABASE_URL=<SUBSTITUTE_SUPABASE_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUBSTITUTE_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUBSTITUTE_SUPABASE_SERVICE_ROLE_KEY>
ANTHROPIC_API_KEY=<SUBSTITUTE_ANTHROPIC_API_KEY>
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VERSION=2023-06-01
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=codellama
OLLAMA_API_KEY=<SUBSTITUTE_OLLAMA_API_KEY>
NVIDIA_API_KEY=<SUBSTITUTE_NVIDIA_API_KEY>
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
OPENROUTER_API_KEY=<SUBSTITUTE_OPENROUTER_API_KEY>
OPENROUTER_MODEL=openrouter/free
# Encrypts pluggable-storage connection configs (any string; hashed to a 32-byte key)
STORAGE_CONFIG_SECRET=<SUBSTITUTE_STORAGE_CONFIG_SECRET>
NEXT_PUBLIC_SENTRY_DSN=<SUBSTITUTE_SENTRY_DSN>
# Optional: only needed for source-map upload at build time
SENTRY_AUTH_TOKEN=<SUBSTITUTE_SENTRY_AUTH_TOKEN>
